# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# AWS
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_DEFAULT_REGION=eu-west-1

# MLflow
MLFLOW_TRACKING_URI=http://your-ec2-dns:5000
MLFLOW_EXPERIMENT_NAME=crop-disease-detection

# S3
MODEL_BUCKET=crop-disease-models-stg-your-account-id
SSM_PARAMETER_NAME=/crop-disease-mlops/staging/run_id

# Inference
PREDICTIONS_STREAM_NAME=crop-disease-predictions
TEST_RUN=True
